rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner() {
      return request.auth != null
        && request.auth.uid == 'fzvLrWhEVjbCBkptrIviP7FQp6q2'
        && request.auth.token.firebase.sign_in_provider == 'password';
    }

    match /users/{userId} {
      allow read: if isOwner() && userId == request.auth.uid;

      match /settings/{doc} {
        allow read, write: if isOwner();
      }

      match /quotations/{qid} {
        allow read, create, update, delete: if isOwner();

        match /revisions/{rev} {
          allow read, create: if isOwner();
          allow update, delete: if false;
        }
      }

      match /counters/{name} {
        allow read: if isOwner();
        allow create: if isOwner()
          && request.resource.data.value is int
          && request.resource.data.value >= 0;
        // Invoice counter is FORWARD-ONLY — it may be incremented by the
        // atomic +1 issued through convertQuotationToInvoice, OR jumped
        // ahead manually through the Advanced "next invoice number" panel
        // (handy for aligning with an external accounting sequence). What
        // it can NEVER do is go backward — that would risk re-issuing a
        // number that's already been used, breaking the audit trail.
        // Quotation counter is permissive: it can move freely (decrements
        // happen when the most-recent draft is deleted, to reclaim the
        // QINV- number and avoid gaps).
        allow update: if isOwner()
          && request.resource.data.value is int
          && (
            (name == 'invoice'
              && request.resource.data.value >= resource.data.value)
            || (name == 'quotation'
              && request.resource.data.value >= 0)
          );
        allow delete: if false;
      }

      match /invoices/{iid} {
        allow read: if isOwner();
        allow create: if isOwner()
          && request.resource.data.keys().hasAll(
              ['version','number','displayNumber','issueDate','createdAt',
               'client','items','total','status'])
          && request.resource.data.number is int
          && request.resource.data.number > 0
          && request.resource.data.createdAt == request.time
          && request.resource.data.status in ['paid'];
        // Invoice numbering is keyed to PAYMENT DATE in this workflow —
        // the latest payment gets the highest number, so the dashboard
        // reads as a clean chronological ledger. That means three fields
        // that used to be immutable now have to be mutable:
        //   • issueDate     (the recorded payment date — user can correct it)
        //   • number        (re-permuted across the existing pool when
        //                    payment dates shift or a new payment lands)
        //   • displayNumber (the formatted twin of `number`)
        // `createdAt` (the original Firestore write time) stays pinned so
        // there is a stable tiebreaker when two payments share a date, and
        // the status flow stays one-way (paid → void).
        allow update: if isOwner()
          && request.resource.data.number is int
          && request.resource.data.number > 0
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.status in ['paid','void']
          && (resource.data.status != 'void' || request.resource.data.status == 'void');
        allow delete: if false;

        match /audit/{eventId} {
          allow read: if isOwner();
          allow create: if isOwner()
            && request.resource.data.ts == request.time;
          allow update, delete: if false;
        }
        match /revisions/{rev} {
          allow read, create: if isOwner();
          allow update, delete: if false;
        }
      }
    }

    // Public share-link mirror. Each saved quotation / invoice writes a
    // sanitised display copy here keyed by an unguessable 16-char token
    // (~82 bits of crypto-grade entropy). Anyone with the URL (and
    // therefore the token) can read; only the owner can write. Tokens
    // are not enumerable — clients can only fetch by exact ID, never
    // list — and the URL contains nothing else (no invoice number, no
    // sequential identifier), so there's nothing to increment.
    match /shares/{token} {
      allow read: if true;
      allow create, update: if isOwner()
        && request.resource.data.ownerUid == 'fzvLrWhEVjbCBkptrIviP7FQp6q2'
        && token.matches('^[a-z0-9]{12,24}$');
      allow delete: if isOwner();
    }

    match /{path=**} { allow read, write: if false; }
  }
}
